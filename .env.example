# ============================================================
#  NexChat — Environment Variables TEMPLATE
#  Optional for this static version. The active Firebase and
#  Cloudinary config is already in config/config.js.
# ============================================================

# ── Firebase Configuration ───────────────────────────────────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# ── Cloudinary Configuration ─────────────────────────────────
# Use an unsigned upload preset only. Never expose your API secret.
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=
VITE_CLOUDINARY_FOLDER=nexchat_uploads

# ── App Configuration ────────────────────────────────────────
VITE_APP_NAME=NexChat
VITE_APP_VERSION=1.0.0
VITE_APP_ENV=production
