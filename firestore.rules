// ============================================================
//  firestore.rules — NexChat Security Rules
//  Deploy with: firebase deploy --only firestore
// ============================================================

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function chatPath(chatId) {
      return /databases/$(database)/documents/chats/$(chatId);
    }

    function callPath(callId) {
      return /databases/$(database)/documents/calls/$(callId);
    }

    function isChatMember(chatId) {
      return isSignedIn()
        && exists(chatPath(chatId))
        && request.auth.uid in get(chatPath(chatId)).data.members;
    }

    function isCallMember(callId) {
      return isSignedIn()
        && exists(callPath(callId))
        && (request.auth.uid == get(callPath(callId)).data.callerId
          || request.auth.uid == get(callPath(callId)).data.calleeId);
    }

    function validTextMessage() {
      return request.resource.data.type == 'text'
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 5000;
    }

    function validAttachmentMessage() {
      return request.resource.data.type in ['image', 'file']
        && request.resource.data.fileName is string
        && request.resource.data.fileName.size() > 0
        && request.resource.data.fileName.size() <= 180
        && request.resource.data.fileUrl is string
        && request.resource.data.fileUrl.size() > 0
        && request.resource.data.fileType is string
        && request.resource.data.fileSize is number
        && request.resource.data.fileSize > 0
        && request.resource.data.fileSize <= 10485760
        && request.resource.data.storagePath is string;
    }

    function validGifMessage() {
      return request.resource.data.type == 'gif'
        && request.resource.data.fileName is string
        && request.resource.data.fileName.size() > 0
        && request.resource.data.fileName.size() <= 180
        && request.resource.data.fileUrl is string
        && request.resource.data.fileUrl.size() > 0
        && request.resource.data.fileType == 'image/gif'
        && request.resource.data.fileSize is number
        && request.resource.data.storagePath is string;
    }

    match /users/{userId} {
      // Users stay hidden in the UI until a search is typed.
      // List access is needed for partial name/email/ID search in this static frontend app.
      allow get, list: if isSignedIn();

      allow create: if isOwner(userId)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.keys().hasOnly(['uid','name','email','nameLower','emailLower','nexId','nexIdLower','photoURL','photoPublicId','searchTokens','online','lastSeen','lastActive','createdAt','updatedAt'])
        && request.resource.data.keys().hasAll(['uid','name','email','online'])
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 1
        && request.resource.data.name.size() <= 100
        && request.resource.data.email is string;

      allow update: if isOwner(userId)
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.email == resource.data.email
        && request.resource.data.keys().hasOnly(['uid','name','email','nameLower','emailLower','nexId','nexIdLower','photoURL','photoPublicId','searchTokens','online','lastSeen','lastActive','createdAt','updatedAt']);

      allow delete: if isOwner(userId);
    }

    match /userLookup/{lookupId} {
      // Exact document get only, used for NexChat ID search.
      allow get: if isSignedIn();
      allow list: if false;

      allow create, update: if isSignedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.keys().hasOnly(['uid','nexId','name','email','photoURL','updatedAt'])
        && request.resource.data.nexId is string
        && request.resource.data.name is string
        && request.resource.data.email is string;

      allow delete: if false;
    }

    match /chats/{chatId} {
      allow get: if isSignedIn()
        && (!exists(chatPath(chatId)) || request.auth.uid in resource.data.members);

      allow list: if isSignedIn();

      allow create: if isSignedIn()
        && request.auth.uid in request.resource.data.members
        && request.resource.data.members is list
        && request.resource.data.members.size() == 2
        && request.resource.data.keys().hasOnly(['members','memberNames','lastMessage','lastMessageTime','lastSenderId','lastSenderName','createdAt'])
        && request.resource.data.keys().hasAll(['members','memberNames','lastMessage','lastMessageTime'])
        && request.resource.data.lastMessage is string;

      allow update: if isChatMember(chatId)
        && request.resource.data.members == resource.data.members
        && request.resource.data.memberNames is map
        && request.resource.data.keys().hasOnly(['members','memberNames','lastMessage','lastMessageTime','lastSenderId','lastSenderName','createdAt'])
        && request.resource.data.lastMessage is string;

      allow delete: if isChatMember(chatId);

      match /messages/{messageId} {
        allow read: if isChatMember(chatId);

        allow create: if isChatMember(chatId)
          && request.resource.data.senderId == request.auth.uid
          && request.resource.data.senderName is string
          && request.resource.data.type in ['text', 'image', 'file', 'gif']
          && request.resource.data.keys().hasOnly(['type','text','senderId','senderName','timestamp','fileName','fileUrl','fileType','fileSize','storagePath','gifId','gifTitle','seenBy','deletedFor'])
          && request.resource.data.keys().hasAll(['type','senderId','senderName','timestamp'])
          && request.resource.data.seenBy is list
          && request.auth.uid in request.resource.data.seenBy
          && request.resource.data.deletedFor is list
          && (validTextMessage() || validAttachmentMessage() || validGifMessage());

        allow update: if isChatMember(chatId)
          && request.resource.data.senderId == resource.data.senderId
          && request.resource.data.type == resource.data.type
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['seenBy','deletedFor'])
          && (!request.resource.data.keys().hasAny(['seenBy']) || request.resource.data.seenBy is list)
          && (!request.resource.data.keys().hasAny(['deletedFor']) || request.resource.data.deletedFor is list);

        allow delete: if isChatMember(chatId);
      }
    }

    match /blocks/{blockId} {
      allow get, list: if isSignedIn();

      allow create, update: if isSignedIn()
        && request.resource.data.blockerId == request.auth.uid
        && request.resource.data.blockedId is string
        && request.resource.data.blockedId != request.auth.uid
        && request.resource.data.keys().hasOnly(['blockerId','blockedId','createdAt']);

      allow delete: if isSignedIn() && resource.data.blockerId == request.auth.uid;
    }

    match /calls/{callId} {
      allow get, list: if isSignedIn();

      allow create: if isSignedIn()
        && request.resource.data.callerId == request.auth.uid
        && request.resource.data.calleeId is string
        && request.resource.data.type in ['audio', 'video']
        && request.resource.data.status == 'ringing'
        && request.resource.data.keys().hasOnly(['chatId','callerId','callerName','calleeId','calleeName','type','offer','answer','status','createdAt','updatedAt']);

      allow update: if isCallMember(callId)
        && request.resource.data.callerId == resource.data.callerId
        && request.resource.data.calleeId == resource.data.calleeId
        && request.resource.data.chatId == resource.data.chatId
        && request.resource.data.type == resource.data.type
        && request.resource.data.status in ['ringing','active','ended','rejected','missed']
        && request.resource.data.keys().hasOnly(['chatId','callerId','callerName','calleeId','calleeName','type','offer','answer','status','createdAt','updatedAt']);

      allow delete: if false;

      match /{candidateCollection}/{candidateId} {
        allow read, create: if isCallMember(callId)
          && candidateCollection in ['callerCandidates','calleeCandidates'];
        allow update, delete: if false;
      }
    }
  }
}
