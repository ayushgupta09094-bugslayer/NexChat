// ============================================================
//  firestore.rules — NexChat Security Rules
//  Deploy with: firebase deploy --only firestore
// ============================================================

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function chatPath(chatId) {
      return /databases/$(database)/documents/chats/$(chatId);
    }

    function isChatMember(chatId) {
      return isSignedIn()
        && exists(chatPath(chatId))
        && request.auth.uid in get(chatPath(chatId)).data.members;
    }

    match /users/{userId} {
      // Needed for the New Conversation page.
      allow read: if isSignedIn();

      // A user document must use the same ID as Firebase Auth UID.
      allow create: if isOwner(userId)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.keys().hasOnly(['uid','name','email','online','lastSeen','createdAt'])
        && request.resource.data.keys().hasAll(['uid','name','email','online'])
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 1
        && request.resource.data.name.size() <= 100
        && request.resource.data.email is string;

      allow update: if isOwner(userId)
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.email == resource.data.email
        && request.resource.data.keys().hasOnly(['uid','name','email','online','lastSeen','createdAt']);

      allow delete: if isOwner(userId);
    }

    match /chats/{chatId} {
      // Existing chat docs can only be opened by their members.
      // Missing chat docs can be checked before creation by any signed-in user.
      allow get: if isSignedIn()
        && (!exists(chatPath(chatId)) || request.auth.uid in resource.data.members);

      // Required for the current user's conversation list query.
      allow list: if isSignedIn();

      allow create: if isSignedIn()
        && request.auth.uid in request.resource.data.members
        && request.resource.data.members is list
        && request.resource.data.members.size() == 2
        && request.resource.data.keys().hasOnly(['members','memberNames','lastMessage','lastMessageTime','createdAt'])
        && request.resource.data.keys().hasAll(['members','memberNames','lastMessage','lastMessageTime'])
        && request.resource.data.lastMessage is string;

      allow update: if isChatMember(chatId)
        && request.resource.data.members == resource.data.members
        && request.resource.data.memberNames == resource.data.memberNames
        && request.resource.data.keys().hasOnly(['members','memberNames','lastMessage','lastMessageTime','createdAt'])
        && request.resource.data.lastMessage is string;

      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isChatMember(chatId);

        allow create: if isChatMember(chatId)
          && request.resource.data.senderId == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 5000
          && request.resource.data.keys().hasOnly(['text','senderId','senderName','timestamp'])
          && request.resource.data.keys().hasAll(['text','senderId','senderName','timestamp']);

        allow update, delete: if false;
      }
    }
  }
}
